# Copy this file to ".env" (same folder) and fill in real values.
# ".env" is gitignored - never commit real keys.

# --- Gemini (already required for running the pipeline) ---
GEMINI_API_KEY=

# --- Supabase (accounts + persistent job storage) ---
# Find these in your Supabase project: Settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
# Settings -> API -> "service_role" key (SECRET - server-side only, never
# expose this to the frontend or commit it anywhere).
SUPABASE_SERVICE_ROLE_KEY=
