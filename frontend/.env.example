# Copy this file to ".env" (same folder, frontend/) and fill in real values.
# ".env" is gitignored - never commit real keys.
#
# These two are safe to expose in the browser bundle by design - Supabase's
# "anon" key is meant to be public; access control is enforced server-side by
# Row Level Security policies (see backend/README_BACKEND.md "Accounts"), not
# by keeping this key secret. Never put the service_role key here.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=
